{
  "description": "Very Good AI Flutter Plugin hooks for Dart and Flutter development",
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "bash ${CLAUDE_PLUGIN_ROOT}/hooks/scripts/analyze.sh",
            "timeout": 30
          },
          {
            "type": "command",
            "command": "bash ${CLAUDE_PLUGIN_ROOT}/hooks/scripts/format.sh",
            "timeout": 30
          }
        ]
      }
    ]
  }
}